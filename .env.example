# База данных
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ollama
OLLAMA_URL=http://localhost:11434
# RAM-бюджет на MacBook Air 16 ГБ:
#   qwen2.5:3b-instruct — ~2 ГБ пик (РЕКОМЕНДУЕТСЯ, зелёная зона)
#   qwen2.5:7b-instruct — ~5 ГБ пик (опция, жёлтая зона; только при запасе RAM)
LLM_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=nomic-embed-text
# Этап 1.2: меньше окно (num_ctx) = меньше RAM под KV-кеш.
# 2048 для 3b-модели: личные заметки + RAM-бюджет 16 ГБ (KV-кеш ~0.5 ГБ vs ~1 ГБ при 3072).
LLM_NUM_CTX=2048
# Резерв токенов под system+вопрос+ответ; контекст чанков собирается до (NUM_CTX - RESERVE)
CTX_RESERVE=900
# Этап 1.3: keepalive Ollama. 2m — модель удерживается между вопросами (интерактив).
# При простое/`/stop` бот передаёт 0, чтобы выгрузить модель (~2 ГБ RAM для 3b).
LLM_KEEPALIVE=2m
# Детерминизм: фикс «после рестарта ответы разные / утечка иероглифов».
# Попытка 0: seed=42, temp=0 — воспроизводимость. Ретраи: рост temp + seed+attempt.
LLM_SEED=42
# Этап 2.3: на основной попытке 0.2 (было 0.1 — слишком жёстко, деградация/отказы).
# Ретраи используют LLM_RETRY_TOP_P=0.3 для диверсификации.
LLM_TOP_P=0.2
LLM_RETRY_TOP_P=0.3
LLM_RETRY_BASE_TEMPERATURE=0.2
LLM_REPEAT_PENALTY=1.1
LLM_RECOVERY_TEMPERATURE=0.2

# Grounding (Этап 2.1): единый порог grounding_score вместо AND-каскада из 5 гейтов.
# score = среднее(word_coverage, trigram_overlap, distinctive_tokens). Калибровать на qa_corpus.
# Этап 4.1: поднят с 0.5 до 0.55 по итогам sweep на qa_corpus — отсекает слабые OOS
# (анти-галлюцинация ↑), сохраняя JSON/HATEOAS/REST (score 0.7–0.98).
GROUNDING_THRESHOLD=0.55
# Этап 2.5: recovery при близком скоринге (score в [threshold-margin, threshold))
GROUNDING_RECOVERY_MARGIN=0.1
# Анти-галлюцинация: доля слов ответа в контексте; выше = строже (больше stub'ов)
GROUNDING_WORD_COVERAGE=0.55
# Посентенсная фильтрация: порог по предложению / мин. доля оставшегося / мин. число предложений
# (min_kept_sentences применяется только к развёрнутым ответам >= 3 предложений — Этап 2.2)
GROUNDING_SENTENCE_COVERAGE=0.55
GROUNDING_MIN_KEPT_RATIO=0.25
GROUNDING_MIN_KEPT_SENTENCES=2

# Telegram (получить у @BotFather)
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
OPEN_ACCESS=false

# RAG
TOP_K=5
SIM_THRESHOLD=0.35
MAX_CONCURRENT_LLM=1

# Источники / синхронизация (CSV абсолютных путей к vault/папкам)
SOURCE_DIRS=/Users/youruser/Documents/Obsidian Vault
IGNORE_DIRS=.obsidian,.trash
GC_RETENTION_DAYS=30