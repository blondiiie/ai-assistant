# База данных
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ollama
OLLAMA_URL=http://localhost:11434
# gemma2:9b — устойчивое понимание (RU, сравнения, отрицание); qwen2.5:3b-instruct — экономнее по RAM
LLM_MODEL=gemma2:9b
EMBED_MODEL=nomic-embed-text

# Telegram (получить у @BotFather)
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
OPEN_ACCESS=false

# RAG
TOP_K=5
SIM_THRESHOLD=0.35
MAX_CONCURRENT_LLM=1

# Источники / синхронизация (CSV абсолютных путей к vault/папкам)
SOURCE_DIRS=/Users/youruser/Documents/Obsidian Vault
IGNORE_DIRS=.obsidian,.trash
GC_RETENTION_DAYS=30
