# База данных
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ollama
OLLAMA_URL=http://localhost:11434
# qwen2.5:7b-instruct — баланс качества (RU, сравнения, отрицание) и RAM (~5ГБ пик vs ~9ГБ у 9b)
LLM_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text
# Меньше окно (num_ctx) = меньше RAM под KV-кеш. 4096 хватает для ~10-12 чанков
LLM_NUM_CTX=4096

# Telegram (получить у @BotFather)
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
OPEN_ACCESS=false

# RAG
TOP_K=5
SIM_THRESHOLD=0.35
MAX_CONCURRENT_LLM=1

# Источники / синхронизация (CSV абсолютных путей к vault/папкам)
SOURCE_DIRS=/Users/youruser/Documents/Obsidian Vault
IGNORE_DIRS=.obsidian,.trash
GC_RETENTION_DAYS=30
